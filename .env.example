# Baseline Chat — environment configuration
# Copy to .env and adjust. All values have sane local defaults.

# LLM provider: "mock" (no API key needed) or "claude" (real Anthropic calls)
BASELINE_LLM_PROVIDER=mock

# Required only when BASELINE_LLM_PROVIDER=claude
# ANTHROPIC_API_KEY=sk-ant-...
BASELINE_CLAUDE_MODEL=claude-opus-4-8

# Database — SQLite locally; swap for a Postgres/Supabase URL in production
BASELINE_DB_URL=sqlite:///baseline.db

# Baseline engine
BASELINE_WINDOW_DAYS=28        # rolling window for personal baseline (28–60)
BASELINE_MIN_HISTORY_DAYS=14   # below this, treat as cold-start (low confidence)
BASELINE_BACKFILL_DAYS=45      # synthetic days generated at onboarding
