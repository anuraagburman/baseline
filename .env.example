# Baseline Chat — environment configuration
# Copy to .env and adjust. Everything runs with mocks by default (no keys needed).
# For production, fill in the provider sections below — see DEPLOY.md.

# ── LLM (coaching) ──────────────────────────────────────────────
# "mock" (no API key) or "claude" (real Anthropic calls)
BASELINE_LLM_PROVIDER=mock
# ANTHROPIC_API_KEY=sk-ant-...
BASELINE_CLAUDE_MODEL=claude-opus-4-8

# ── Vision (food-photo → macros) ────────────────────────────────
# "mock" or "claude" (uses ANTHROPIC_API_KEY above)
BASELINE_VISION_PROVIDER=mock

# ── Database ────────────────────────────────────────────────────
# SQLite locally; a Postgres/Supabase URL in production
BASELINE_DB_URL=sqlite:///baseline.db

# ── Baseline engine ─────────────────────────────────────────────
BASELINE_WINDOW_DAYS=28        # rolling window for personal baseline (28–60)
BASELINE_MIN_HISTORY_DAYS=14   # below this, treat as cold-start (low confidence)
BASELINE_BACKFILL_DAYS=45      # synthetic days generated at onboarding

# ── WhatsApp (Twilio) — absent ⇒ LocalChannel (no real messages) ─
# BASELINE_TWILIO_ACCOUNT_SID=ACxxxxxxxx
# BASELINE_TWILIO_AUTH_TOKEN=xxxxxxxx
BASELINE_TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Name of the approved Twilio utility template for the daily nudge
BASELINE_WHATSAPP_TEMPLATE_NAME=baseline_daily_checkin

# ── Google Health OAuth — absent ⇒ MockOAuthProvider + synthetic ─
# BASELINE_GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
# BASELINE_GOOGLE_CLIENT_SECRET=xxxxxxxx
BASELINE_GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/oauth/google/callback

# ── Hosting / proactive nudge ───────────────────────────────────
# Public HTTPS base URL of the deployed app (used for OAuth + connect links)
BASELINE_PUBLIC_BASE_URL=http://localhost:8000
# Secret required in the X-Cron-Secret header to trigger POST /cron/daily-nudge
# BASELINE_CRON_SECRET=choose-a-long-random-string
